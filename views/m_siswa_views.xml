<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_m_siswa_form" model="ir.ui.view">
            <field name="name">m.siswa.form</field>
            <field name="model">m.siswa</field>
            <field name="arch" type="xml">
                <form string="Profil Siswa">
                    <sheet>
                        <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                        <group>
                            <group string="Data Siswa">
                                <field name="name"/> <!-- New direct name field -->
                                <field name="class_name"/>
                                <field name="status"/>
                                <field name="join_date"/>
                            </group>
                            <group string="Data Akademik">
                                <field name="level_id" options="{'no_create': True}"/>
                                <field name="class_type_id" options="{'no_create': True}"/>
                                <field name="jadwal_hari"/>
                                <field name="jadwal_jam" widget="float_time"/>
                                <field name="skema_pembayaran"/>
                                <field name="product_id" domain="[('sale_ok', '=', True)]"/>
                                <!-- Removed semester field -->
                            </group>
                            <group string="Data Penanggung Jawab">
                                <field name="parent_id"/>
                                <field name="parent_contact"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Riwayat Kursus">
                                <field name="enrollment_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="modul_id"/>
                                        <field name="status"/>
                                        <field name="tanggal_mulai"/>
                                        <field name="tanggal_selesai"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Portofolio &amp; Karya">
                                <group>
                                    <group string="Profil Publik">
                                        <field name="portfolio_slug" placeholder="misal: aril-saputra"/>
                                        <field name="bio_singkat" placeholder="Bio singkat untuk halaman publik..."/>
                                        <field name="profile_image_url" widget="url" readonly="1"/>
                                    </group>
                                </group>
                                <separator string="Daftar Karya / Proyek"/>
                                <field name="portfolio_project_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="category"/>
                                        <field name="project_url" widget="url"/>
                                        <field name="create_date" string="Dibuat"/>
                                    </tree>
                                    <form string="Detail Karya">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="name"/>
                                                    <field name="category"/>
                                                </group>
                                                <group>
                                                    <field name="project_url" widget="url"/>
                                                </group>
                                            </group>
                                            <group string="Deskripsi">
                                                <field name="description" nolabel="1" placeholder="Ceritakan tentang karya ini..."/>
                                            </group>
                                            <notebook>
                                                <page string="Media (Foto/Video)">
                                                    <field name="media_ids">
                                                        <kanban>
                                                            <field name="id"/>
                                                            <field name="media_type"/>
                                                            <templates>
                                                                <t t-name="kanban-box">
                                                                    <div class="oe_kanban_global_click">
                                                                        <div class="o_kanban_image">
                                                                            <field name="file_url" invisible="1"/>
                                                                            <img t-if="record.file_url.raw_value" t-att-src="record.file_url.raw_value" alt="Media" class="o_image_64_contain"/>
                                                                            <t t-if="!record.file_url.raw_value">
                                                                                <img t-if="record.media_type.raw_value == 'image'" t-att-src="kanban_image('student.portfolio.project.media', 'file_data', record.id.raw_value)" alt="Media" class="o_image_64_contain"/>
                                                                                <div t-if="record.media_type.raw_value == 'video'" class="fa fa-file-video-o fa-5x text-center"/>
                                                                            </t>
                                                                        </div>
                                                                        <div class="oe_kanban_details">
                                                                            <field name="media_type"/>
                                                                        </div>
                                                                    </div>
                                                                </t>
                                                            </templates>
                                                        </kanban>
                                                        <form>
                                                            <group>
                                                                <field name="media_type"/>
                                                                <field name="file_data" filename="file_name" widget="binary" attrs="{'invisible': [('file_url', '!=', False)]}"/>
                                                                <field name="file_url" widget="url" attrs="{'invisible': [('file_url', '=', False)]}"/>
                                                                <field name="file_name" invisible="1"/>
                                                                <field name="sequence"/>
                                                            </group>
                                                        </form>
                                                    </field>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Catatan">
                                 <field name="notes" placeholder="Catatan tambahan..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_m_siswa_tree" model="ir.ui.view">
            <field name="name">m.siswa.tree</field>
            <field name="model">m.siswa</field>
            <field name="arch" type="xml">
                <tree string="Profil Siswa">
                    <field name="name"/> <!-- New direct name field -->
                    <field name="class_name"/>
                    <field name="level_id"/>
                    <field name="class_type_id"/>
                    <field name="jadwal_hari"/>
                    <field name="jadwal_jam" widget="float_time"/>
                    <field name="parent_id"/>
                    <field name="parent_contact"/>
                    <field name="status"/>
                    <field name="join_date"/>
                </tree>
            </field>
        </record>
        
        <record id="view_m_siswa_search" model="ir.ui.view">
            <field name="name">m.siswa.search</field>
            <field name="model">m.siswa</field>
            <field name="arch" type="xml">
                <search string="Cari Siswa">
                    <field name="name" string="Nama Siswa"/>
                    <field name="parent_id" string="Nama Orang Tua"/>
                    <field name="class_type_id"/>
                    <field name="level_id"/>
                    <separator/>
                    <filter name="status_active" string="Siswa Aktif" domain="[('status', '=', 'active')]"/>
                    <filter name="status_inactive" string="Siswa Tidak Aktif" domain="[('status', '=', 'inactive')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_level" string="Level" context="{'group_by': 'level_id'}"/>
                        <filter name="group_by_class_type" string="Jenis Kelas" context="{'group_by': 'class_type_id'}"/>
                        <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_m_siswa" model="ir.actions.act_window">
            <field name="name">Database Siswa</field>
            <field name="res_model">m.siswa</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_m_siswa_search"/>
            <field name="context">{'search_default_status_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Belum ada data siswa.
                </p><p>
                    Klik 'Create' untuk mendaftarkan siswa baru.
                </p>
            </field>
        </record>

    </data>
</odoo>
