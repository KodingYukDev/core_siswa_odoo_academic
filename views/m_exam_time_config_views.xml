<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_exam_time_config_tree" model="ir.ui.view">
        <field name="name">exam.time.config.tree</field>
        <field name="model">exam.time.config</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="exam_type"/>
                <field name="duration_minutes"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_exam_time_config_form" model="ir.ui.view">
        <field name="name">exam.time.config.form</field>
        <field name="model">exam.time.config</field>
        <field name="arch" type="xml">
            <form string="Konfigurasi Waktu Ujian">
                <sheet>
                    <group>
                        <field name="exam_type"/>
                        <field name="duration_minutes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_exam_time_config" model="ir.actions.act_window">
        <field name="name">Master Waktu Ujian</field>
        <field name="res_model">exam.time.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
