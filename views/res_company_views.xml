<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_rapot_koordinator" model="ir.ui.view">
        <field name="name">res.company.form.rapot.koordinator</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Rapot Ekskul">
                    <field name="rapot_koordinator_name"/>
                    <field name="rapot_koordinator_signature" widget="image" class="oe_avatar"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
