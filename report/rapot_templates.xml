<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Halaman rapot generik: 1 t-call = 1 halaman untuk 1 siswa.
         Dipakai baik oleh report siswa privat/reguler/online (students)
         maupun report siswa ekskul/sekolah (database_sekolah). -->
    <template id="rapot_page" name="Halaman Rapot Siswa">
        <div class="page" style="font-family: Arial, sans-serif; font-size: 11.5px; color: #1a1a1a;">

            <!-- Header -->
            <table style="width:100%; border-bottom: 3px solid #FFD200; padding-bottom: 8px; margin-bottom: 16px;">
                <tr>
                    <td style="width: 55%; vertical-align: middle;">
                        <img src="/students/static/src/img/logo_kodingyuk.png" style="height: 48px;"/>
                    </td>
                    <td style="width: 45%; text-align: right; vertical-align: middle;">
                        <h2 style="margin: 0; color: #1E2A78; font-size: 18px;">RAPOT HASIL BELAJAR</h2>
                        <div style="color: #6A7197; font-size: 11px;" t-esc="doc.modul_id.name or ''"/>
                    </td>
                </tr>
            </table>

            <!-- Identitas -->
            <table style="width:100%; margin-bottom: 16px; font-size: 12px;">
                <tr>
                    <td style="width: 16%; font-weight: bold; padding: 2px 0;">Nama</td>
                    <td style="width: 34%; padding: 2px 0;" t-esc="doc.rapot_nama_siswa or '-'"/>
                    <td style="width: 16%; font-weight: bold; padding: 2px 0;">Kelas</td>
                    <td style="width: 34%; padding: 2px 0;" t-esc="doc.rapot_kelas or '-'"/>
                </tr>
                <tr t-if="doc.rapot_sekolah_nama">
                    <td style="font-weight: bold; padding: 2px 0;">Sekolah</td>
                    <td t-esc="doc.rapot_sekolah_nama"/>
                    <td style="font-weight: bold; padding: 2px 0;">Level</td>
                    <td t-esc="doc.rapot_level or '-'"/>
                </tr>
                <tr t-else="">
                    <td style="font-weight: bold; padding: 2px 0;">Level</td>
                    <td t-esc="doc.rapot_level or '-'"/>
                    <td/>
                    <td/>
                </tr>
            </table>

            <!-- Kriteria Penilaian -->
            <div style="font-weight: bold; margin-bottom: 6px; color: #1E2A78;">Kriteria Penilaian</div>
            <table style="width:100%; border-collapse: collapse; margin-bottom: 12px; font-size: 11px;">
                <thead>
                    <tr style="background: #1E2A78; color: #fff;">
                        <th style="padding: 6px; width: 6%; border: 1px solid #1E2A78;">No</th>
                        <th style="padding: 6px; width: 26%; text-align: left; border: 1px solid #1E2A78;">Aspek Penilaian</th>
                        <th style="padding: 6px; text-align: left; border: 1px solid #1E2A78;">Keterangan</th>
                        <th style="padding: 6px; width: 10%; border: 1px solid #1E2A78;">Skor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="doc.assessment_line_ids" t-as="line">
                        <td style="padding: 5px; text-align: center; border: 1px solid #ddd;" t-esc="line_index + 1"/>
                        <td style="padding: 5px; border: 1px solid #ddd; font-weight: 600;" t-esc="line.name"/>
                        <td style="padding: 5px; border: 1px solid #ddd;" t-esc="line.description or ''"/>
                        <td style="padding: 5px; text-align: center; border: 1px solid #ddd; font-weight: 600;" t-esc="('%g' % line.score).replace('.', ',')"/>
                    </tr>
                    <tr style="background: #f5f5f5; font-weight: bold;">
                        <td colspan="3" style="padding: 6px; border: 1px solid #ddd; text-align: right;">Total Skor</td>
                        <td style="padding: 6px; border: 1px solid #ddd; text-align: center;" t-esc="('%.1f' % doc.average_score).replace('.', ',')"/>
                    </tr>
                </tbody>
            </table>

            <!-- Nilai Akhir -->
            <table style="width:100%; margin-bottom: 10px; font-size: 12px;">
                <tr>
                    <td style="font-weight: bold; width: 30%;">Nilai Akhir (Huruf)</td>
                    <td style="font-weight: bold; color: #1E2A78;" t-esc="doc.nilai_huruf or '-'"/>
                </tr>
            </table>

            <div style="font-size: 10px; color: #555; margin-bottom: 16px; line-height: 1.5;">
                <strong>Keterangan:</strong><br/>
                90 - 100 : Sangat Baik (A)<br/>
                80 - 89 &#160;&#160;: Baik (B)<br/>
                70 - 79 &#160;&#160;: Cukup (C)<br/>
                &lt; 70 &#160;&#160;&#160;&#160;&#160;: Perlu Bimbingan (D)
            </div>

            <!-- Catatan -->
            <div t-if="doc.catatan" style="margin-bottom: 20px;">
                <div style="font-weight: bold; margin-bottom: 4px;">Catatan Untuk Peserta Didik:</div>
                <p style="border: 1px solid #ddd; padding: 8px; border-radius: 4px; min-height: 40px; margin: 0;" t-esc="doc.catatan"/>
            </div>

            <!-- Tanda Tangan -->
            <table style="width:100%; margin-top: 30px; font-size: 11.5px;">
                <tr>
                    <td style="width: 50%; text-align: center;">
                        <div>Pelatih/Pembina</div>
                        <div style="height: 65px; display: flex; align-items: flex-end; justify-content: center;">
                            <img t-if="doc.pelatih_id.signature_image" t-att-src="image_data_uri(doc.pelatih_id.signature_image)" style="max-height: 60px;"/>
                        </div>
                        <div style="border-top: 1px solid #333; padding-top: 4px; font-weight: bold;" t-esc="doc.pelatih_id.name or '(.........................)'"/>
                    </td>
                    <td style="width: 50%; text-align: center;">
                        <div>Mengetahui,<br/>Koordinator Ekskul</div>
                        <div style="height: 65px; display: flex; align-items: flex-end; justify-content: center;">
                            <img t-if="doc.company_id.rapot_koordinator_signature" t-att-src="image_data_uri(doc.company_id.rapot_koordinator_signature)" style="max-height: 60px;"/>
                        </div>
                        <div style="border-top: 1px solid #333; padding-top: 4px; font-weight: bold;" t-esc="doc.company_id.rapot_koordinator_name or '(.........................)'"/>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <!-- Wrapper report untuk siswa.kursus.penilaian.sertifikat (privat/reguler/online) -->
    <template id="report_rapot_siswa">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="students.rapot_page"/>
            </t>
        </t>
    </template>

    <record id="action_report_rapot_siswa" model="ir.actions.report">
        <field name="name">Cetak Rapot</field>
        <field name="model">siswa.kursus.penilaian.sertifikat</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">students.report_rapot_siswa</field>
        <field name="report_file">students.report_rapot_siswa</field>
        <field name="paperformat_id" ref="paperformat_rapot"/>
        <field name="binding_model_id" ref="model_siswa_kursus_penilaian_sertifikat"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
