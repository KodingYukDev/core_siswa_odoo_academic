<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Halaman rapot generik: 1 t-call = 1 halaman untuk 1 siswa.
         Layout mengikuti template resmi "Rapot Ekstrakurikuler" (docx/PDF KodingYuk).
         Dipakai oleh report siswa privat/reguler/online (students) dan
         siswa ekskul/sekolah (database_sekolah). -->
    <template id="rapot_page" name="Halaman Rapot Siswa">
        <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 11.5px; color: #000;">

            <!-- Kop: logo KodingYuk kiri, judul 3 baris tengah, logo sekolah kanan (jika ada),
                 garis tebal bawah. Logo di-embed base64 agar pasti ke-render wkhtmltopdf. -->
            <table style="width:100%; border-bottom: 3px solid #000; padding-bottom: 6px; margin-bottom: 14px;">
                <tr>
                    <td style="width: 17%; vertical-align: middle;">
                        <img t-att-src="'data:image/png;base64,%s' % doc.get_rapot_logo_base64()" style="max-height: 58px; max-width: 100%;"/>
                    </td>
                    <td style="width: 66%; text-align: center; vertical-align: middle; font-family: 'Times New Roman', 'Liberation Serif', Times, serif; font-weight: bold; font-size: 16px; line-height: 1.5;">
                        <div t-esc="'RAPOT EKSTRAKURIKULER' if doc.rapot_sekolah_nama else 'RAPOT KURSUS'"/>
                        <div t-esc="' '.join(filter(None, [
                            (doc.modul_id.name or '').upper(),
                            ('SEMESTER %s' % doc.semester) if doc.semester else None,
                            ('TAHUN AJARAN %s' % doc.tahun_ajaran) if doc.tahun_ajaran else None,
                        ]))"/>
                        <div t-if="doc.rapot_sekolah_nama" t-esc="doc.rapot_sekolah_nama.upper()"/>
                    </td>
                    <td style="width: 17%; text-align: right; vertical-align: middle;">
                        <img t-if="doc.rapot_sekolah_logo" t-att-src="image_data_uri(doc.rapot_sekolah_logo)" style="max-height: 58px; max-width: 100%;"/>
                    </td>
                </tr>
            </table>

            <!-- Identitas -->
            <table style="margin-bottom: 4px; font-size: 12px;">
                <tr>
                    <td style="width: 90px; padding: 1px 0;">Nama</td>
                    <td style="width: 14px;">:</td>
                    <td style="padding: 1px 0;" t-esc="doc.rapot_nama_siswa or '-'"/>
                </tr>
                <tr>
                    <td style="padding: 1px 0;">Kelas</td>
                    <td>:</td>
                    <td style="padding: 1px 0;" t-esc="doc.rapot_kelas or '-'"/>
                </tr>
                <tr>
                    <td style="padding: 1px 0;">Level</td>
                    <td>:</td>
                    <td style="padding: 1px 0;" t-esc="doc.rapot_level or '-'"/>
                </tr>
            </table>

            <div style="font-weight: bold; margin-bottom: 6px;">Kriteria Penilaian :</div>

            <!-- Tabel 1: aspek penilaian modul -->
            <table style="width:100%; border-collapse: collapse; margin-bottom: 12px; font-size: 11px;">
                <thead>
                    <tr>
                        <th style="padding: 5px; width: 6%; border: 1px solid #000; text-align: center;">No</th>
                        <th style="padding: 5px; width: 20%; border: 1px solid #000; text-align: center;">Aspek Penilaian</th>
                        <th style="padding: 5px; border: 1px solid #000; text-align: center;">Keterangan</th>
                        <th style="padding: 5px; width: 9%; border: 1px solid #000; text-align: center;">Skor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="doc.assessment_line_ids" t-as="line">
                        <td style="padding: 4px 5px; text-align: center; border: 1px solid #000; font-weight: bold;" t-esc="line_index + 1"/>
                        <td style="padding: 4px 5px; border: 1px solid #000; font-weight: bold;" t-esc="line.name"/>
                        <td style="padding: 4px 5px; border: 1px solid #000;" t-esc="line.description or ''"/>
                        <td style="padding: 4px 5px; text-align: center; border: 1px solid #000;" t-esc="('%g' % line.score).replace('.', ',')"/>
                    </tr>
                    <tr>
                        <td colspan="3" style="padding: 5px; border: 1px solid #000; text-align: center; font-weight: bold;">Total Skor</td>
                        <td style="padding: 5px; border: 1px solid #000; text-align: center; font-weight: bold;" t-esc="('%.1f' % doc.average_score).replace('.', ',')"/>
                    </tr>
                </tbody>
            </table>

            <!-- Legend (pakai hyphen biasa, hindari entity yang mojibake di wkhtmltopdf) -->
            <div style="font-weight: bold; margin-bottom: 4px;">Keterangan</div>
            <table style="font-size: 11.5px; margin-bottom: 16px; line-height: 1.6;">
                <tr><td style="width: 70px;">90 - 100</td><td style="width: 14px;">:</td><td>Sangat Baik (A)</td></tr>
                <tr><td>80 - 89</td><td>:</td><td>Baik (B)</td></tr>
                <tr><td>70 - 79</td><td>:</td><td>Cukup (C)</td></tr>
            </table>

            <!-- Tabel 2: rubrik aspek umum + catatan -->
            <t t-set="rubrik_lines" t-value="doc.rubrik_line_ids.sorted(key=lambda l: (l.sequence, l.id))"/>
            <table t-if="rubrik_lines" style="width:100%; border-collapse: collapse; margin-bottom: 24px; font-size: 11.5px;">
                <thead>
                    <tr>
                        <th style="padding: 5px; width: 6%; border: 1px solid #000; text-align: center;">No</th>
                        <th style="padding: 5px; width: 32%; border: 1px solid #000; text-align: center;">Aspek Penilaian</th>
                        <th style="padding: 5px; width: 12%; border: 1px solid #000; text-align: center;">Skor</th>
                        <th style="padding: 5px; border: 1px solid #000; text-align: center;">Catatan Untuk Peserta Didik</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="rubrik_lines" t-as="rline">
                        <td style="padding: 5px; text-align: center; border: 1px solid #000;" t-esc="rline_index + 1"/>
                        <td style="padding: 5px; border: 1px solid #000;" t-esc="rline.name"/>
                        <td style="padding: 5px; text-align: center; border: 1px solid #000;" t-esc="('%g' % rline.score).replace('.', ',')"/>
                        <td t-if="rline_index == 0" t-att-rowspan="len(rubrik_lines)"
                            style="padding: 6px 8px; border: 1px solid #000; vertical-align: top;"
                            t-esc="doc.catatan or ''"/>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding: 5px; border: 1px solid #000; font-weight: normal;">Total Score</td>
                        <td style="padding: 5px; text-align: center; border: 1px solid #000;" t-esc="('%g' % doc.rubrik_total).replace('.', ',')"/>
                        <td style="border: 1px solid #000;"/>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding: 5px; border: 1px solid #000;">Nilai Akhir (Huruf)</td>
                        <td style="padding: 5px; text-align: center; border: 1px solid #000; font-weight: bold;" t-esc="doc.nilai_huruf_letter or ''"/>
                        <td style="border: 1px solid #000;"/>
                    </tr>
                </tbody>
            </table>

            <!-- Catatan fallback bila rubrik kosong -->
            <div t-if="not rubrik_lines and doc.catatan" style="margin-bottom: 20px;">
                <div style="font-weight: bold; margin-bottom: 4px;">Catatan Untuk Peserta Didik:</div>
                <p style="border: 1px solid #000; padding: 8px; min-height: 40px; margin: 0;" t-esc="doc.catatan"/>
            </div>

            <!-- Tanda tangan: Koordinator Ekskul (pihak sekolah) kiri, Pelatih/Pembina kanan.
                 Rapot privat tanpa sekolah: hanya Pelatih/Pembina di kanan. -->
            <table style="width:100%; margin-top: 18px; font-size: 11.5px;">
                <tr>
                    <td style="width: 50%; vertical-align: top;">
                        <t t-if="doc.rapot_sekolah_nama">
                            <div style="font-weight: bold;">Mengetahui,<br/>Koordinator Ekskul</div>
                            <div style="height: 70px; vertical-align: bottom;">
                                <img t-if="doc.rapot_koordinator_signature" t-att-src="image_data_uri(doc.rapot_koordinator_signature)" style="max-height: 65px;"/>
                            </div>
                            <div t-if="doc.rapot_koordinator_name" style="font-weight: bold; text-decoration: underline;" t-esc="doc.rapot_koordinator_name"/>
                            <div t-else="">....................................</div>
                        </t>
                    </td>
                    <td style="width: 50%; vertical-align: top; text-align: center;">
                        <div style="font-weight: bold;">Pelatih/Pembina</div>
                        <div style="height: 70px;">
                            <img t-if="doc.pelatih_id.signature_image" t-att-src="image_data_uri(doc.pelatih_id.signature_image)" style="max-height: 65px;"/>
                        </div>
                        <div t-if="doc.pelatih_id" style="font-weight: bold;" t-esc="doc.pelatih_id.name"/>
                        <div t-else="">....................................</div>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <!-- Wrapper report untuk siswa.kursus.penilaian.sertifikat (privat/reguler/online) -->
    <template id="report_rapot_siswa">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="students.rapot_page"/>
            </t>
        </t>
    </template>

    <record id="action_report_rapot_siswa" model="ir.actions.report">
        <field name="name">Cetak Rapot</field>
        <field name="model">siswa.kursus.penilaian.sertifikat</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">students.report_rapot_siswa</field>
        <field name="report_file">students.report_rapot_siswa</field>
        <field name="paperformat_id" ref="paperformat_rapot"/>
        <field name="binding_model_id" ref="model_siswa_kursus_penilaian_sertifikat"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
